# Получить токен у @BotFather в Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Получить на console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Настрой под клиента (можно оставить дефолтный)
SYSTEM_PROMPT=You are a helpful assistant. Be concise and friendly. Answer in the language the user writes in.
