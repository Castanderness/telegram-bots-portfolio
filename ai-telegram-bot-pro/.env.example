# @BotFather -> /newbot
TELEGRAM_TOKEN=your_token_here

# console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Твой Telegram user_id (узнать у @userinfobot)
ADMIN_IDS=123456789

# Лимит бесплатных сообщений в день
FREE_DAILY_LIMIT=20

# Настрой под свой бизнес
SYSTEM_PROMPT=You are a helpful assistant. Be concise and friendly. Answer in the language the user writes in.
